{
  "expo": {
    "name": "FitTrax+",
    "slug": "fittrax-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fittraxplus",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fittraxplus.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan food items and barcodes for quick nutrition logging.",
        "NSPhotoLibraryUsageDescription": "Save progress photos and share your fitness achievements.",
        "NSMicrophoneUsageDescription": "Record personalized voice greetings for your dashboard.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.fittrax.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64f7c6ff-d91c-4923-a070-da634dfe7ac1"
      }
    },
    "owner": "ajajz71"
  }
}
