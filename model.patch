-----------------+test_result() {
-----------------+    local test_name="$1"
-----------------+    local success="$2"
-----------------+    local details="$3"
-----------------+    
-----------------+    TOTAL_TESTS=$((TOTAL_TESTS + 1))
-----------------+    
-----------------+    if [ "$success" = "true" ]; then
-----------------+        echo "✅ PASS: $test_name"
-----------------+        PASSED_TESTS=$((PASSED_TESTS + 1))
-----------------+    else
-----------------+        echo "❌ FAIL: $test_name"
-----------------+    fi
-----------------+    
-----------------+    if [ -n "$details" ]; then
-----------------+        echo "   $details"
-----------------+    fi
-----------------+}
-----------------+
-----------------+echo ""
-----------------+echo "🏥 HEALTH & ADMIN ENDPOINTS"
-----------------+
